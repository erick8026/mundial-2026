      "notes": "Usa la misma credencial OpenAI del RODAI AGENTE V2.\nModelo: gpt-4.1-mini (~$0.0001/msg)"
    },
    {
      "id": "aaaa0016",
      "name": "Extraer Bienvenida",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2120, 140],
      "parameters": {
        "jsCode": "// El nodo OpenAI devuelve el texto en message.content o content\nconst output = $input.first().json;\nconst text = output.message?.content || output.content || output.choices?.[0]?.message?.content || '✅ ¡Suscrito al Mundial 2026! Recibirás alertas de partidos, goles y resultados. Responde STOP para cancelar.';\nconst phone = $('Parsear Mensaje').first().json.phone;\nreturn [{ json: { phone, mensajeGenerado: text.trim() } }];"
      }
    },
    {
      "id": "aaaa0008",
      "name": "Enviar Bienvenida",
