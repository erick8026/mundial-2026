        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ to: $('Parsear Mensaje').first().json.phone, type: 'text', text: { body: '\\u2705 \\u00a1Listo! Est\\u00e1s suscrito a las alertas del *Mundial 2026* \\ud83c\\udfc6\\u26bd\\n\\nTe avisar\\u00e9:\\n\\u2022 30 min antes de cada partido\\n\\u2022 Cuando haya goles\\n\\u2022 El resultado final\\n\\nEnv\\u00eda *STOP* en cualquier momento para cancelar.' } }) }}",
        "options": {}
      },
      "notesInFlow": true,
      "notes": "Ajusta la URL de Kapso si es diferente.\nReemplaza PEGAR_KAPSO_API_KEY_AQUI con tu API Key real."
    },
