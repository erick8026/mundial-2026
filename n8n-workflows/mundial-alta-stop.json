{
  "name": "🌍 Mundial 2026 — WhatsApp ALTA / STOP",
  "nodes": [
    {
      "id": "aaaa0001",
      "name": "Kapso Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [200, 400],
      "parameters": {
        "path": "mundial-kapso",
        "responseMode": "onReceived",
        "httpMethod": "POST",
        "options": {}
      },
      "notesInFlow": true,
      "notes": "ENDPOINT para Kapso:\nProducción: https://TU-N8N/webhook/mundial-kapso\nTest:       https://TU-N8N/webhook-test/mundial-kapso\n\nAjustar el formato en el nodo 'Parsear Mensaje'\nsi el payload de Kapso difiere."
    },
    {
      "id": "aaaa0002",
      "name": "Parsear Mensaje",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 400],
      "parameters": {
        "jsCode": "const body = $input.first().json;\n\nlet phone = '';\nlet messageText = '';\n\n// --- Formato Kapso (ajustar si es necesario) ---\nif (body.from) {\n  phone = String(body.from);\n  messageText = typeof body.text === 'string'\n    ? body.text\n    : (body.text?.body || body.message || '');\n}\n// --- Formato Meta WhatsApp Cloud API ---\nelse if (body.entry?.[0]?.changes?.[0]?.value?.messages) {\n  const msg = body.entry[0].changes[0].value.messages[0];\n  phone = msg.from;\n  messageText = msg.text?.body || '';\n}\n// --- Fallback genérico ---\nelse {\n  phone = String(body.phone || body.sender || body.wa_id || body.from || '');\n  messageText = String(body.message || body.body || body.text || '');\n}\n\n// Limpiar teléfono (quitar +, espacios, guiones)\nphone = phone.replace(/[\\s+\\-().]/g, '');\n\n// Detectar acción\nconst msgUp = messageText.trim().toUpperCase();\nlet action = 'OTHER';\nif (msgUp.includes('ALTA') && msgUp.includes('MUNDIAL')) action = 'ALTA';\nelse if (msgUp === 'STOP' || msgUp.startsWith('STOP ')) action = 'STOP';\n\nreturn [{ json: { phone, messageText, action, timestamp: new Date().toISOString() } }];"
      }
    },
    {
      "id": "aaaa0003",
      "name": "¿Es ALTA?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 400],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "combinator": "and",
          "conditions": [
            {
              "id": "ifalta1",
              "leftValue": "={{ $json.action }}",
              "rightValue": "ALTA",
              "operator": { "type": "string", "operation": "equals" }
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "aaaa0004",
      "name": "Leer Suscriptores",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [920, 260],
      "parameters": {
        "operation": "read",
        "documentId": {
          "__rl": true,
          "value": "PEGAR_SPREADSHEET_ID_AQUI",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Suscriptores",
          "mode": "name"
        },
        "filtersUI": {},
        "options": { "returnAllMatchingRows": true }
      },
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "REEMPLAZAR_CON_TU_CREDENTIAL_ID",
          "name": "Google Sheets"
        }
      },
      "notesInFlow": true,
      "notes": "Reemplaza el Spreadsheet ID y reconecta\nla credencial de Google Sheets."
    },
    {
      "id": "aaaa0005",
      "name": "Verificar Si Existe",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1160, 260],
      "parameters": {
        "jsCode": "const phone = $('Parsear Mensaje').first().json.phone;\nconst rows = $input.all();\n\nconst found = rows.find(r => {\n  const rowPhone = String(r.json.phone || r.json.Phone || '').replace(/[\\s+]/g, '');\n  const active = String(r.json.active || r.json.Active || 'FALSE').toUpperCase();\n  return rowPhone === phone && active === 'TRUE';\n});\n\nreturn [{ json: {\n  phone,\n  alreadyActive: !!found,\n  timestamp: $('Parsear Mensaje').first().json.timestamp\n}}];"
      }
    },
    {
      "id": "aaaa0006",
