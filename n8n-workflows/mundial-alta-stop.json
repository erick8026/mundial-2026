            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ to: $json.phone, type: 'text', text: { body: $json.mensajeGenerado } }) }}",
        "options": {}
      },
      "notesInFlow": true,
      "notes": "Ventana 24h activa — el usuario acaba\nde escribir ALTA. Sin riesgo de spam."
