   ],
   "parameters": {
    "httpMethod": "POST",
    "path": "keepalive-run",
    "options": {}
   },
   "webhookId": "c2d5269a-ef97-437c-b9cf-c25187ae8e1e"
  },
  {
   "id": "ka-select",
   "name": "KA — Ventanas por Vencer",
   "type": "n8n-nodes-base.postgres",
   "typeVersion": 2.5,
   "position": [
    240,
    100
   ],
   "credentials": {
    "postgres": {
     "id": "lZiJmyplRgdvifzN",
     "name": "PG Local RODAI"
    }
   },
   "parameters": {
    "operation": "executeQuery",
    "query": "SELECT s.phone, s.name, to_char(s.last_message_at, 'YYYY-MM-DD HH24:MI:SS') AS ventana_id\nFROM suscriptores s\nWHERE s.platform = 'whatsapp' AND s.active = true\n  AND NOW() >= s.last_message_at + INTERVAL '23 hours'\n  AND NOW() <  s.last_message_at + INTERVAL '24 hours'\n  AND NOT EXISTS (\n    SELECT 1 FROM alertas_enviadas a\n    WHERE a.phone = s.phone AND a.tipo = 'keepalive' AND a.detalle = to_char(s.last_message_at, 'YYYY-MM-DD HH24:MI:SS')\n  )"
   }
  },
  {
   "id": "ka-dedup",
   "name": "KA — Registrar Envío (dedup)",
   "type": "n8n-nodes-base.postgres",
   "typeVersion": 2.5,
   "position": [
    480,
    100
   ],
   "credentials": {
    "postgres": {
     "id": "lZiJmyplRgdvifzN",
     "name": "PG Local RODAI"
    }
   },
   "parameters": {
    "operation": "executeQuery",
    "query": "={{ \"WITH ins AS (INSERT INTO alertas_enviadas (phone, partido_id, tipo, detalle) VALUES ('\" + $json.phone + \"', 'ventana', 'keepalive', '\" + $json.ventana_id + \"') ON CONFLICT DO NOTHING RETURNING id) SELECT COALESCE((SELECT id FROM ins), -1) AS ins_id, '\" + $json.phone + \"' AS phone, '\" + ($json.name || '').replace(/'/g, \"''\") + \"' AS name\" }}"
   }
  },
  {
   "id": "ka-if",
   "name": "KA — ¿Primera vez esta ventana?",
   "type": "n8n-nodes-base.if",
   "typeVersion": 2.2,
   "position": [
    720,
    100
   ],
   "parameters": {
    "conditions": {
     "options": {
      "caseSensitive": false,
      "typeValidation": "loose"
     },
     "conditions": [
      {
       "leftValue": "={{ $json.ins_id }}",
       "rightValue": -1,
       "operator": {
        "type": "number",
        "operation": "notEquals"
       }
      }
     ],
     "combinator": "and"
    }
   }
  },
  {
   "id": "ka-send",
   "name": "KA — Enviar Keep-Alive",
   "type": "n8n-nodes-base.httpRequest",
   "typeVersion": 4.2,
   "position": [
    960,
    0
   ],
   "parameters": {
    "method": "POST",
    "url": "https://api.kapso.ai/meta/whatsapp/v24.0/1365226796664715/messages",
    "sendHeaders": true,
    "headerParameters": {
     "parameters": [
      {
       "name": "X-API-KEY",
       "value": "168d831e9f6e1e36601accc6d72c4e4229c1a20e38126f63f59096a04b842da7"
      },
      {
       "name": "Content-Type",
       "value": "application/json"
      }
     ]
    },
    "sendBody": true,
    "specifyBody": "json",
    "jsonBody": "={{ { \"messaging_product\": \"whatsapp\", \"to\": $json.phone, \"type\": \"text\", \"text\": { \"body\": \"⚽ ¡El Mundial sigue HOY! ¿Quién crees que gana el próximo partido? 🤔\\n\\nRespóndeme tu pronóstico y sigue recibiendo goles y resultados en tiempo real 🔥\\n\\nResponde STOP para darte de baja.\" } } }}"
   }
  },
  {
