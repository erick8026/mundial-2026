    "text": "=⏰ Keep-alive enviado a {{ $('KA — Registrar Envío (dedup)').item.json.name || $('KA — Registrar Envío (dedup)').item.json.phone }} (+{{ $('KA — Registrar Envío (dedup)').item.json.phone }}) — su ventana 24h vencía en menos de 1 hora.",
    "additionalFields": {
     "appendAttribution": false
    }
   },
